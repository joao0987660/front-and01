    <title>GameHub | Sua Biblioteca de Jogos</title>
    <style>
        /* RESET E CORES GAMER */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        
        body { 
            background-color: #0a0a0a; /* Fundo Preto */
            color: #ffffff;
            line-height: 1.6;
        }

        /* HEADER NEON */
        header {
            padding: 40px 20px;
            text-align: center;
            background: linear-gradient(to bottom, #1a1a1a, #0a0a0a);
            border-bottom: 2px solid #8a2be2; /* Roxo Neon */
        }
        header h1 { font-size: 3rem; letter-spacing: 4px; color: #8a2be2; text-shadow: 0 0 10px #8a2be2; }
        header p { color: #00ff88; font-weight: bold; }

        /* GRID DE JOGOS */
        .container { max-width: 1200px; margin: 40px auto; padding: 0 20px; }
        .game-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }

        /* CARDS DOS JOGOS */
        .game-card {
            background: #151515;
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid #333;
            transition: 0.4s;
        }
        .game-card:hover {
            transform: scale(1.05);
            border-color: #00ff88; /* Verde Neon */
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
        }
        .game-img { width: 100%; height: 200px; object-fit: cover; filter: grayscale(30%); transition: 0.4s; }
        .game-card:hover .game-img { filter: grayscale(0%); }

        .game-info { padding: 20px; }
        .game-info h2 { font-size: 1.5rem; margin-bottom: 10px; color: #fff; }
        
        /* TAGS DE INFO */
        .tag {
            display: inline-block;
            padding: 4px 10px;
            background: #222;
            border-radius: 4px;
            font-size: 0.8rem;
            margin-right: 5px;
            margin-bottom: 15px;
            color: #00ff88;
            border: 1px solid #00ff88;
        }

        .description { font-size: 0.9rem; color: #bbb; margin-bottom: 20px; height: 60px; overflow: hidden; }

        /* BOTÃO PLAY */
        .btn-play {
