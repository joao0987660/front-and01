<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GameHub | Loja de Jogos</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background-color: #050505; color: #fff; overflow-x: hidden; }

        /* HEADER */
        header { padding: 30px; text-align: center; border-bottom: 2px solid #00ff88; background: #000; position: sticky; top: 0; z-index: 10; }
        header h1 { color: #00ff88; text-transform: uppercase; letter-spacing: 3px; }

        /* GRID DE JOGOS */
        .container { max-width: 1000px; margin: 40px auto; padding: 0 20px; transition: 0.3s; }
        .game-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }

        .game-card { background: #111; border-radius: 12px; overflow: hidden; border: 1px solid #222; text-align: center; padding-bottom: 20px; }
        .game-img { width: 100%; height: 200px; object-fit: cover; }
        .game-info h2 { margin: 15px 0; font-size: 1.5rem; }
        .price-tag { color: #00ff88; font-size: 1.3rem; font-weight: bold; margin-bottom: 15px; display: block; }

        .btn-buy { background: #00ff88; color: #000; border: none; padding: 12px 25px; border-radius: 5px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .btn-buy:hover { background: #fff; transform: scale(1.05); }

        /* CARRINHO LATERAL */
        #cart-sidebar {
            position: fixed; right: -350px; top: 0; width: 350px; height: 100%;
            background: #111; border-left: 2px solid #00ff88; transition: 0.4s;
            padding: 20px; z-index: 100; box-shadow: -10px 0 30px rgba(0,0,0,0.5);
        }
        #cart-sidebar.active { right: 0; }
        .cart-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333; padding-bottom: 10px; margin-bottom: 20px; }
        
        #cart-items { list-style: none; max-height: 60vh; overflow-y: auto; }
        .cart-item { display: flex; justify-content: space-between; margin-bottom: 15px; background: #1a1a1a; padding: 10px; border-radius: 5px; font-size: 0.9rem; }
        
        .cart-total { border-top: 1px solid #333; padding-top: 20px; margin-top: 20px; font-size: 1.2rem; }
        .btn-checkout { background: #00ff88; border: none; width: 100%; padding: 15px; font-weight: bold; margin-top: 20px; cursor: pointer; border-radius: 5px; }

        /* BOTÃO FLUTUANTE DO CARRINHO */
        .cart-icon-float { position: fixed; bottom: 30px; right: 30px; background: #00ff88; color: #000; padding: 15px 20px; border-radius: 50px; font-weight: bold; cursor: pointer; z-index: 50; box-shadow: 0 5px 15px rgba(0,255,136,0.4); }
    </style>
</head>
<body>

<header>
    <h1>GAME HUB STORE</h1>
</header>

<!-- Botão do Carrinho -->
<div class="cart-icon-float" onclick="toggleCart()">🛒 Carrinho (<span id="cart-count">0</span>)</div>

<!-- Carrinho Lateral -->
<div id="cart-sidebar">
    <div class="cart-header">
        <h2>Seu Carrinho</h2>
        <button onclick="toggleCart()" style="background:none; border:none; color:#ff4444; cursor:pointer; font-weight:bold;">FECHAR [X]</button>
    </div>
    <ul id="cart-items">
        <!-- Itens entram aqui via JS -->
    </ul>
    <div class="cart-total">
        <strong>Total: R$ <span id="cart-total-value">0.00</span></strong>
    </div>
    <button class="btn-checkout" onclick="alert('Compra finalizada com sucesso!')">FINALIZAR COMPRA</button>
</div>

<div class="container">
    <div class="game-grid">
        
        <!-- Jogo 1 -->
        <article class="game-card">
            <img class="game-img" src="https://unsplash.com" alt="Elden Ring">
            <div class="game-info">
                <h2>Elden Ring</h2>
                <span class="price-tag">R$ 249.90</span>
                <button class="btn-buy" onclick="addToCart('Elden Ring', 249.90)">ADICIONAR AO CARRINHO</button>
            </div>
        </article>

        <!-- Jogo 2 -->
        <article class="game-card">
            <img class="game-img" src="https://unsplash.com" alt="Cyberpunk 2077">
            <div class="game-info">
                <h2>Cyberpunk 2077</h2>
                <span class="price-tag">R$ 199.00</span>
                <button class="btn-buy" onclick="addToCart('Cyberpunk 2077', 199.00)">ADICIONAR AO CARRINHO</button>
            </div>
        </article>

    </div>
</div>

<script>
    let cart = [];
    let total = 0;

    function toggleCart() {
        document.getElementById('cart-sidebar').classList.toggle('active');
    }

    function addToCart(name, price) {
        cart.push({name, price});
        total += price;
        updateCartUI();
        
        // Abre o carrinho automaticamente ao adicionar
        if(!document.getElementById('cart-sidebar').classList.contains('active')) {
            toggleCart();
        }
    }

    function updateCartUI() {
        const cartList = document.getElementById('cart-items');
        const cartCount = document.getElementById('cart-count');
        const totalDisplay = document.getElementById('cart-total-value');
        
        cartList.innerHTML = '';
        cart.forEach((item, index) => {
            const li = document.createElement('li');
            li.className = 'cart-item';
            li.innerHTML = `<span>${item.name}</span> <strong>R$ ${item.price.toFixed(2)}</strong>`;
            cartList.appendChild(li);
        });

        cartCount.innerText = cart.length;
        totalDisplay.innerText = total.toFixed(2);
    }
</script>

</body>
</html>



